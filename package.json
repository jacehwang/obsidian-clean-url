{
  "name": "obsidian-clean-url",
  "version": "0.1.1",
  "description": "Clean tracking parameters from pasted URLs while preserving your Markdown syntax.",
  "main": "main.js",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && bun esbuild.config.mjs production",
    "format": "biome format --write .",
    "test": "bun test",
    "version": "bun version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "plugin",
    "url"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@eslint/js": "9.39.4",
    "esbuild": "0.27.4",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "obsidian": "1.12.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  }
}
